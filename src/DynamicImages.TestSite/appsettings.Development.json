{
  "$schema": "./appsettings-schema.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    },
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "Umbraco": {
    "CMS": {
      "Content": {
        "MacroErrors": "Throw"
      },
      "Hosting": {
        "Debug": true
      },
      "RuntimeMinification": {
        "UseInMemoryCache": true,
        "CacheBuster": "Timestamp"
      }
    }
  },
  "uSync": {
    "Settings": {
      "ImportOnFirstBoot": true,
    }
  },
  "DynamicImages": {
    "Enabled": true,
    "Instructions": [
      {
        "ImageName": "Dynamic Image",
        "DocTypeAlias": "issue",
        "Author": "An Author",
        "TargetPropertyAlias": "socialImage",
        "SourceImagePath": "/assets/skrift-background.png",
        "Layers": [
          {
            "LayerType": 0,
            "SourcePropertyAlias": "name",
            "xPosition": 50,
            "yPosition": 60,
            "Colour": "#ff00ff"
          }
        ]
      }
    ],
    "Fonts": [
      "/assets/fonts/OpenSans-Regular.ttf"
    ]
  }
}
