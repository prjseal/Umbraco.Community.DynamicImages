{
  "$schema": "./appsettings-schema.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    },
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "Umbraco": {
    "CMS": {
      "Content": {
        "MacroErrors": "Throw"
      },
      "Hosting": {
        "Debug": true
      },
      "RuntimeMinification": {
        "UseInMemoryCache": true,
        "CacheBuster": "Timestamp"
      }
    }
  },
  "uSync": {
    "Settings": {
      "ImportOnFirstBoot": true,
    }
  },
  "DynamicImages": {
    "Enabled": true,
    "Instructions": [
      {
        "ImageName": "Dynamic Image",
        "DocTypeAlias": "issue",
        "Author": "An Author",
        "TargetPropertyAlias": "socialImage",
        "SourceImagePath": "/assets/skrift-background.png",
        "Layers": [
          {
            "LayerType": 0,
            "SourcePropertyAlias": "name",
            "xPosition": 50,
            "yPosition": 60,
            "Colour": "#c13ea9",
            "Font": "OpenSans_Large"
          },
          {
            "LayerType": 0,
            "SourcePropertyAlias": "author",
            "xPosition": 178,
            "yPosition": 526,
            "Colour": "#c13ea9",
            "Font": "OpenSans_Small"
          },
          {
            "LayerType": 0,
            "SourcePropertyAlias": "issueNumber",
            "xPosition": 526,
            "yPosition": 526,
            "Colour": "#c13ea9",
            "Font": "OpenSans_Small"
          },
          {
            "LayerType": 0,
            "SourcePropertyAlias": "issueDate",
            "DateFormat": "dd MMMM yyyy",
            "xPosition": 606,
            "yPosition": 526,
            "Colour": "#ffffff",
            "Font": "OpenSans_Small"
          }
        ]
      }
    ],
    "Fonts": [
      {
        "FamilyName": "OpenSans",
        "Path": "/assets/fonts/OpenSans-Regular.ttf",
        "Styles": [
          {
            "Name": "Small",
            "Size": 30,
            "Style": 1
          },
          {
            "Name": "Large",
            "Size": 80,
            "Style": 1
          }
        ]
      }
    ]
  }
}
